# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ona

# Auth
JWT_SECRET=change-me-in-production

# API
API_PORT=8000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# AI providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# USDA FoodData Central (https://fdc.nal.usda.gov/api-key-signup)
USDA_FDC_API_KEY=

# Picovoice Porcupine wake-word (https://console.picovoice.ai)
# Required to enable "Hola Ona" detection on the client. Without it,
# voice mode falls back to the floating mic FAB at top-right.
NEXT_PUBLIC_PICOVOICE_ACCESS_KEY=
