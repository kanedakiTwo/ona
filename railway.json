{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pnpm install"
  },
  "deploy": {
    "startCommand": "./node_modules/.bin/tsx apps/api/src/db/migrate.ts && ./node_modules/.bin/tsx apps/api/src/seed/index.ts && ./node_modules/.bin/tsx apps/api/src/index.ts",
    "restartPolicyType": "ON_FAILURE"
  }
}
